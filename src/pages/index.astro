---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ProfileSidebar from '../components/ProfileSidebar.astro';

const posts = (await getCollection('docs'))
  .filter((doc) => doc.data.type === 'post')
  .sort((a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0));
---

<Base title="Accueil" wide>
  <div class="home-layout">
    <ProfileSidebar />

    <section class="home-articles">
      <h2 class="section-title">Articles</h2>
      {posts.length === 0 ? (
        <p class="empty-state">Aucun article publié pour le moment.</p>
      ) : (
        <ul class="article-grid">
          {posts.map((post) => (
            <li>
              <a class="article-card" href={post.data.permalink}>
                <div class="article-card-top">
                  {post.data.category && (
                    <span class="article-category">{post.data.category}</span>
                  )}
                  {post.data.date && (
                    <time datetime={post.data.date.toISOString()}>
                      {post.data.date.toLocaleDateString('fr-FR', {
                        day: 'numeric',
                        month: 'short',
                        year: 'numeric',
                      })}
                    </time>
                  )}
                </div>
                <h3>{post.data.title}</h3>
                {post.data.description && <p>{post.data.description}</p>}
              </a>
            </li>
          ))}
        </ul>
      )}
    </section>
  </div>
</Base>
