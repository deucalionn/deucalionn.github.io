---
import Base from './Base.astro';

interface Props {
  doc: import('astro:content').CollectionEntry<'docs'>;
}

const { doc } = Astro.props;
const { title, description, date, category, tags } = doc.data;
---

<Base title={title} description={description}>
  <article>
    <h1>{title}</h1>
    <div class="meta">
      {date && <time datetime={date.toISOString()}>{date.toLocaleDateString('fr-FR')}</time>}
      {category && (
        <>
          {' · '}
          <a class="category-pill" href={`/categories/${category}/`}>{category}</a>
        </>
      )}
      {tags.length > 0 && (
        <div class="tags">
          {tags.map((tag) => (
            <a class="tag" href={`/tags/${encodeURIComponent(tag)}/`}>{tag}</a>
          ))}
        </div>
      )}
    </div>
    <slot />
  </article>
</Base>
